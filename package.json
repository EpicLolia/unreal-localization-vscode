{
  "name": "unreal-localization",
  "displayName": "Unreal Localization for VS Code",
  "description": "Unreal Localization for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "publisher": "loiafeng",
  "repository": {
    "url": "https://github.com/EpicLolia/unreal-localization-vscode"
  },
  "files": [
    "dist/extension.js",
    "LICENSE"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "unreal-localization.reload",
        "title": "Unreal Localization: Reload"
      }
    ],
    "configuration": {
      "title": "Unreal Localization",
      "properties": {
        "unreal-localization.defaultCulture": {
          "type": "string",
          "default": "en",
          "description": "Culture used as the data source (folder name under <root>/<target>)."
        },
        "unreal-localization.root": {
          "type": "string",
          "default": "Content/Localization",
          "description": "Localization root, relative to each workspace folder, or an absolute path."
        },
        "unreal-localization.target": {
          "type": "string",
          "default": "Game",
          "description": "Localization target name (folder under <root>; the .locres file is <target>.locres)."
        },
        "unreal-localization.patterns": {
          "type": "array",
          "default": [
            {
              "name": "GetText(ns, key)",
              "files": [
                "**/*.{ts,js,cpp,h}"
              ],
              "regex": "GetText\\(\\s*\"(?<ns>[^\"]*)\"\\s*,\\s*\"(?<key>[^\"]*)\"\\s*\\)"
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "name",
              "files",
              "regex"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name shown in warnings and logs."
              },
              "files": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Glob patterns this rule applies to."
              },
              "regex": {
                "type": "string",
                "markdownDescription": "Regex with named groups `ns` and `key`. Use `[^\"]*` (allowing empty content) so completion fires before the literal is closed."
              }
            }
          },
          "description": "Patterns recognised as localization calls."
        },
        "unreal-localization.diagnosticsSeverity": {
          "type": "string",
          "enum": [
            "hint",
            "information",
            "warning",
            "error"
          ],
          "default": "information",
          "description": "Severity for missing namespace/key diagnostics."
        }
      }
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "watch:check": "tsc --noEmit --watch -p tsconfig.json",
    "build": "npm run check && node esbuild.js",
    "watch:build": "node esbuild.js --watch",
    "package": "npm run check && node esbuild.js --production && npx vsce package",
    "test": "tsc -p tsconfig.json --outDir out && vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.103.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
